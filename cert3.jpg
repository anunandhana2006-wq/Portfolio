E068B56FA67AF7DE82B45AD041578" data-testid="conv-msg-AC7E068B56FA67AF7DE82B45AD041578"><div class="x78zum5 xdt5ytf" data-virtualized="true" style="min-height: 173.976px;"><div class=""></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="AC12C2DD416E17CEE83B8F2756C5EB81" data-testid="conv-msg-AC12C2DD416E17CEE83B8F2756C5EB81"><div class="x78zum5 xdt5ytf" data-virtualized="true" style="min-height: 53.9757px;"><div class=""></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="3EB03CEEE0399C9BB1523A" data-testid="conv-msg-3EB03CEEE0399C9BB1523A"><div class="x78zum5 xdt5ytf" data-virtualized="true" style="min-height: 147.917px;"><div class=""></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="3EB0ED7F33FD1F13FCDF2C" data-testid="conv-msg-3EB0ED7F33FD1F13FCDF2C"><div class="x78zum5 xdt5ytf" data-virtualized="true" style="min-height: 716.979px;"><div class=""></div></div></div></div></div><div><div tabindex="-1" class="" role="row"><div tabindex="-1" class="_amjv xa0aww2" data-id="3EB03FE5C992DBDAEC9008" data-testid="conv-msg-3EB03FE5C992DBDAEC9008"><div class="x78zum5 xdt5ytf" data-virtualized="false"><div class=""><div class="message-out focusable-list-item _amjy _amjz _amjw x1klvx2g xahtqtb"><span class=""></span><div data-testid="msg-container" class="_amk4 false false _amkd false"><div class="_amk6 _amlo false false"><div><div class="x9f619 x1hx0egp x1yrsyyn xizg8k xu9hqtb xwib8y2"><div class="copyable-text" data-pre-plain-text="[9:34 PM, 5/28/2026] Anu: "><div class="_akbu x6ikm8r x10wlt62"><span data-testid="selectable-text" dir="ltr" class="x1f6kntn xjb2p0i x8r4c90 xo1l8bm x1ic7a3i x12xpedu _ao3e _aupe copyable-text" style="min-height: 0px;"><span class="x1lliihq">body {
</span><span class="x1lliihq">  margin: 0;
</span><span class="x1lliihq">  font-family: Arial, sans-serif;
</span><span class="x1lliihq">  background: linear-gradient(135deg, #0f172a, #1e293b);
</span><span class="x1lliihq">  color: white;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Header */
</span><span class="x1lliihq">header {
</span><span class="x1lliihq">  text-align: center;
</span><span class="x1lliihq">  padding: 60px 20px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">header h1 {
</span><span class="x1lliihq">  font-size: 40px;
</span><span class="x1lliihq">  margin-bottom: 10px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Sections */
</span><span class="x1lliihq">section {
</span><span class="x1lliihq">  max-width: 800px;
</span><span class="x1lliihq">  margin: 20px auto;
</span><span class="x1lliihq">  padding: 20px;
</span><span class="x1lliihq">  background: rgba(255, 255, 255, 0.08);
</span><span class="x1lliihq">  border-radius: 15px;
</span><span class="x1lliihq">  backdrop-filter: blur(10px);
</span><span class="x1lliihq">  box-shadow: 0 0 15px rgba(0,0,0,0.3);
</span><span class="x1lliihq">  transition: 0.3s ease;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* Hover effect */
</span><span class="x1lliihq">section:hover {
</span><span class="x1lliihq">  transform: translateY(-5px);
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">/* List styling */
</span><span class="x1lliihq">ul {
</span><span class="x1lliihq">  padding-left: 20px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">li {
</span><span class="x1lliihq">  margin: 5px 0;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">.buttons {
</span><span class="x1lliihq">  display: flex;
</span><span class="x1lliihq">  justify-content: center;
</span><span class="x1lliihq">  gap: 15px;
</span><span class="x1lliihq">  margin-top: 10px;
</span><span class="x1lliihq">}
</span><span class="x1lliihq">
</span><span class="x1lliihq">button {
</span><span class="x1lliihq">  padding: 10px 15px;
</span><span class="">  …</span></span> <div role="button" tabindex="0" data-testid="caption-read-more-button" class="xuxw1ft x1ypdohk x1rg5ohu xo1mcw5 x1xlr1w8 x1hl2dhg xt0b8zv xbvygy2 x17f7hit xp30eni xhmieyt read-more-button">Read more</div><span class=""><span class="x3nfvp2 xxymvpz xlshs6z xqtp20y xexx8yu x1uc92m x18d9i69 x181vq82 x12lo8hy x152skdk" aria-hidden="true"><span class="x1c4vz4f x2lah0s xn6xy2s"></span><span class="x1c4vz4f x2lah0s">9:34 PM</span></span></span></div></div><div class="x1n2onr6 x1n327nk x18mqm2i xhsvlbd x14z9mp xz62fqu x1wbi8v6"><div class="x1bvqhpb xx3o462 xuxw1ft x78zum5 x6s0dn4 x12lo8hy x152skdk" data-testid="msg-meta" role="button"><span class="x1rg5ohu x16dsc37" dir="auto"><span class="x193iq5w xeuugli x13faqbe x1vvkbs xt0psk2 x1fj9vlw xhslqc4 x1hx0egp x1pg5gke xjb2p0i xo1l8bm xl2ypbo x1ic7a3i" style="--x-fontSize: 12px; --x-lineHeight: 8.5313px;">9:34 PM</span></span><div class="xhslqc4 x1rg5ohu x7phf20"><span data-testid="msg-dblcheck" aria-hidden="false" aria-label=" Read " data-icon="msg-dblcheck" class="x1rv0e52"><svg viewBox="0 0 16 11" height="11" width="16" preserveAspectRatio="xMidYMid meet" class="" fill="none"><title>msg-dblcheck</title><path d="M11.0714 0.652832C10.991 0.585124 10.8894 0.55127 10.7667 0.55127C10.6186 0.55127 10.4916 0.610514 10.3858 0.729004L4.19688 8.36523L1.79112 6.09277C1.7488 6.04622 1.69802 6.01025 1.63877 5.98486C1.57953 5.95947 1.51817 5.94678 1.45469 5.94678C1.32351 5.94678 1.20925 5.99544 1.11192 6.09277L0.800883 6.40381C0.707784 6.49268 0.661235 6.60482 0.661235 6.74023C0.661235 6.87565 0.707784 6.98991 0.800883 7.08301L3.79698 10.0791C3.94509 10.2145 4.11224 10.2822 4.29844 10.2822C4.40424 10.2822 4.5058 10.259 4.60313 10.2124C4.70046 10.1659 4.78086 10.1003 4.84434 10.0156L11.4903 1.59863C11.5623 1.5013 11.5982 1.40186 11.5982 1.30029C11.5982 1.14372 11.5348 1.01888 11.4078 0.925781L11.0714 0.652832ZM8.6212 8.32715C8.43077 8.20866 8.2488 8.09017 8.0753 7.97168C7.99489 7.89128 7.8891 7.85107